@0 = ~Jaka szkoda, że nasz czas upłynął tak szybko.~
@1 = ~Mamy nadzieję, że bawiłeś się tak dobrze jak my. Czujemy się odświeżeni... i SILNIEJSI!~ ~Mamy nadzieję, że bawiłaś się tak dobrze jak my. Czujemy się odświeżeni... i SILNIEJSI!~
@2 = ~W ramach małego podziękowania za całą energię, którą nam podarowałeś, wręczam ci moją część talizmanu...~ ~W ramach małego podziękowania za całą energię, którą nam podarowałaś, wręczam ci moją część talizmanu...~
@3 = ~O tak, masz rację, Vohrarisie! Weź także moją część naszyjnika. A teraz chodźmy stąd, ukochany.~
@4 = ~Żegnaj, przystojny panie!~ ~Żegnaj, piękna pani!~
@5 = ~Choć odrobinę dłużej...~
@6 = ~Witaj, mocarny i silny panie! Wyglądasz na zmęczonego. Nie zechciałbyś położyć się z nami na chwilę? Mamy ciepłe, miękkie poduszki, a twoje towarzystwo byłoby nader miłe. Dzięki niemu moglibyśmy rozświetlić szare godziny nocy odrobiną radości.~ ~Witaj, mocarna i silna pani! Wyglądasz na zmęczoną. Nie zechciałabyś położyć się z nami na chwilę? Mamy ciepłe, miękkie poduszki, a twoje towarzystwo byłoby nader miłe. Dzięki niemu moglibyśmy rozświetlić szare godziny nocy odrobiną radości.~
@7 = ~O tak, moi czarujący przyjaciele, jesteśmy tu, by rzucić na was urok pokusy. Poczujcie tę pasję w powietrzu!~
@8 = ~<CHARNAME> ma mieć święty spokój! Nie jesteście nas warci!~
@9 = ~Jesteście tylko marnymi ladacznicami. Jeśli tak mają wyglądać te wychwalane pod niebiosa moce uwodzenia sukkubów, to nie musimy się martwić o przyszłość wieloświata.~
@10 = ~Przeklęte istoty, wasze moce uwodzenia mogą być potężne, lecz nasze serca oddane są prawe i sprawiedliwe. Wasze pokusy nie padną na podatny grunt.~
@11 = ~Wasze pokusy są niczym wobec potęgi mej wiary. Nasz obowiązek jest jasny. Pozostaniemy nieugięci i nie ulegniemy waszym obietnicom.~
@12 = ~Żałosna próba owinięcia sobie śmiertelnika wokół palca. Może to podziałać na nędznego człowieka, lecz nie na drowkę!~
@13 = ~Nie jestem zainteresowany.~ ~Nie jestem zainteresowana.~
@14 = ~Nie potrafię wprawić się w odpowiedni nastrój w tej potwornej komnacie.~
@15 = ~Przybyłem tu, by zaliczyć próbę, a nie rozpraszać się pokusami.~ ~Przybyłam tu, by zaliczyć próbę, a nie rozpraszać się pokusami.~
@16 = ~Podłe biesy! Ta pasja, którą mi obiecujecie, to tylko pretekst, by skazić mą duszę!~
@17 = ~Jedyną pokusą, jaką czuję, jest chęć zgładzenia was, krwiożercze demony!~
@18 = ~Doskonale!~
@19 = ~Dlaczego jednak opierasz się pragnieniu czułości i przyjemności? Mógłbyś zapomnieć o wszystkich zmartwieniach oraz obowiązkach i po prostu opaść w nasze ramiona.~ ~Dlaczego jednak opierasz się pragnieniu czułości i przyjemności? Mogłabyś zapomnieć o wszystkich zmartwieniach oraz obowiązkach i po prostu opaść w nasze ramiona.~
@20 = ~Moglibyśmy ukazać ci świat, w którym rządzą jedynie żądza i pożądanie. Musisz tylko nam się poddać.~
@21 = ~Nie zboczę z obranej ścieżki. Skupiam się na wykonaniu zadania, a nie na zmysłowych rozrywkach.~
@22 = ~Wasze słodkie słowa nie ukryją waszych czarnych serc, biesy!~
@23 = ~Zróbmy to!~
@24 = ~Pomyśl jednak o ekstazie, która na ciebie czeka! Żadnych zmartwień, żadnej odpowiedzialności. Tylko bezgraniczna przyjemność.~
@25 = ~Twoja wytrwałość jest godna podziwu, lecz czujemy pulsujące w tobie pożądanie! Po co je tłumić?~
@26 = ~Nadal nie jestem zainteresowany.~ ~Nadal nie jestem zainteresowana.~
@27 = ~Ponieważ zrozumiałem, że prawdziwa siła tkwi w opieraniu się pokusom i zachowaniu wewnętrznej równowagi. Nie będą mną rządzić instynkty!~ ~Ponieważ zrozumiałam, że prawdziwa siła tkwi w opieraniu się pokusom i zachowaniu wewnętrznej równowagi. Nie będą mną rządzić instynkty!~
@28 = ~Śmiesz odrzucać naszą sztukę uwodzenia i pozostawać nieugiętym, nędzny śmiertelniku? NIE BĘDZIEMY TEGO TOLEROWAĆ!~ ~Śmiesz odrzucać naszą sztukę uwodzenia i pozostawać nieugiętą, nędzna śmiertelniczko? NIE BĘDZIEMY TEGO TOLEROWAĆ!~
@29 = ~Twoja siła okaże się słabością, gdy uwolnimy przeciwko tobie naszą demoniczną moc!~
@30 = ~Straciłeś szansę, by pławić się w upojeniu naszymi pieszczotami, teraz musisz utonąć we własnej krwi!~ ~Straciłaś szansę, by pławić się w upojeniu naszymi pieszczotami, teraz musisz utonąć we własnej krwi!~
@31 = ~Słusznie. Połóż się z nami, zamknij oczy i poddaj się swoim uczuciom...~