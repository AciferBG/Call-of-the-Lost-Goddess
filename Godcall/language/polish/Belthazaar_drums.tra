@0 = ~Witajcie, wielkoludy!~
@1 = ~Myślałem, że przyzywam glabrezu, a nie jakiegoś quasita.~ ~Myślałam, że przyzywam glabrezu, a nie jakiegoś quasita.~
@2 = ~Przywołaj glabrezu Belthazaara.~
@3 = ~Cierpliwości, cierpliwości! Belthazaar, wielki glabrezu, nadchodzi. Zostałem wysłany przodem tylko po to, by sprawdzić, czy teren jest czysty!~
@4 = ~Zatem przywołaj go.~
@5 = ~Hmm... dajcie mi się rozejrzeć...~
@6 = ~Czas jeszcze nie nadszedł! Nie bądźcie tacy niecierpliwi!~
@7 = ~Wygląda na to, że wszystko w porządku! Mój mistrz pojawi się tu lada chwila, przygotujcie się!~
@8 = ~Przestań gadać i walcz!~
@9 = ~Wy głupcy! Mojego mistrza nie da się przywołać tutaj, w Otchłani! Można to zrobić tylko w Sferze Materialnej!~