@0 = ~Stójcie, głupi śmiertelnicy, i słuchajcie naszych słów! Wkraczacie do Komnaty Pokus, miejsca pełnego prób i niebezpieczeństw. Czekają tu na was pułapki oraz pokusy, w które dacie się usidlić.~ 
@1 = ~W tej komnacie wasze najskrytsze pragnienia zostaną uwolnione, a najbardziej ukryte tęsknoty wyjawione.~
@2 = ~Ulegnijcie, a czeka was WIEKUISTA UDRĘKA!~ 
@3 = ~Ulegnijcie, a skończycie jako kolejni grzesznicy w Otchłani!~ 
@4 = ~Masz różę! Nie spodziewałbym się tego. Coś, czemu sam nie podołałem! Przeklęte próby, zbyt łatwo ulegam pokusom. Jak miło, że zerwałeś tę różę dla mnie!~ ~Masz różę! Nie spodziewałbym się tego. Coś, czemu sam nie podołałem! Przeklęte próby, zbyt łatwo ulegam pokusom. Jak miło, że zerwałaś tę różę dla mnie!~ 
@5 = ~Odbiorę ją twoim zwłokom i wręczę Maretcie, by mogła zostać mą nową przeklętą panią!~ 
@6 = ~To dość przebiegłe, lecz zarazem tchórzliwe, by unikać prób i usiłować skraść nam różę.~ 