@0 = ~Udało się?~
@1 = ~Powiedziałem temu biednemu kupcowi prawdę o twoich machinacjach!~ ~Powiedziałam temu biednemu kupcowi prawdę o twoich machinacjach!~
@2 = ~Co? To fatalnie. Denuncjować mnie tutaj, na oczach moich konkurentów! Pfff. Nie pozwolę, żeby byle wędrowny chłopaczyna robił ze mnie głupca!~ ~Co? To fatalnie. Denuncjować mnie tutaj, na oczach moich konkurentów! Pfff. Nie pozwolę, żeby byle wędrowna dziewucha robiła ze mnie głupca!~
@3 = ~Co się stało? Dlaczego nie podłożyłeś papryczki tak, jak się umawialiśmy? Nigdy nie widziałem, żeby lord opuszczał namiot Zakhuma z takim entuzjazmem!~ ~Co się stało? Dlaczego nie podłożyłaś papryczki tak, jak się umawialiśmy? Nigdy nie widziałem, żeby lord opuszczał namiot Zakhuma z takim entuzjazmem!~
@4 = ~Obawiam się, że plan ze strąkiem przyniósł odwrotny skutek. Szlachcic był wręcz wniebowzięty ostrą potrawą!~
@5 = ~CO? Jak to możliwe? I co teraz?~
@6 = ~Obawiam się, że nie wskoczysz na pierwsze miejsce w rankingu najlepszych handlarzy przypraw!~
@7 = ~Skąd właściwie wziąłeś tą paprykę?~
@8 = ~Dał mi ją pewien mag. Przywołał biesa. Na Tymorę, nawet nie chcę sobie wyobrażać, co by było, gdyby...~
@9 = ~To... to wszystko wasza wina! Niech to szlag! Och, zostawcie mnie w spokoju...~
@10 = ~Im szybciej podrzucisz tę papryczkę do przypraw Zakhuma, tym szybciej dostaniesz zapłatę.~
@11 = ~Pozdrowienia. Zamierzasz wejść do namiotu Zakhuma, najlepszego handlarza przypraw w Amn?~
@12 = ~Kim jesteś?~
@13 = ~Tak, masz z tym jakiś problem?~
@14 = ~Pozwól, że się przedstawię. Nazywam się Masun i jestem... drugim najlepszym handlarzem przypraw w Amn.~
@15 = ~Drugim najlepszym?~
@16 = ~Miło mi cię poznać.~
@17 = ~Tak, i nie zamierzam na tym poprzestać! Słuchaj więc uważnie.~
@18 = ~Nie wyglądasz na typowego klienta, którego obchodzą wykwintne przyprawy. Ten Zakhum, OBECNIE najlepszy handlarz przypraw w Amn, spodziewa się wkrótce ważnego gościa i liczy na złoty interes. Szukam kogoś, kto mógłby przekonać tego jegomościa... przekonać go, że to JA jestem lepszym wyborem. Rozumiesz? Dzięki temu to ja zostałbym najlepszym handlarzem przypraw w krainie.~ ~Nie wyglądasz na typową klientkę, którą obchodzą wykwintne przyprawy. Ten Zakhum, OBECNIE najlepszy handlarz przypraw w Amn, spodziewa się wkrótce ważnego gościa i liczy na złoty interes. Szukam kogoś, kto mógłby przekonać tego jegomościa... przekonać go, że to JA jestem lepszym wyborem. Rozumiesz? Dzięki temu to ja zostałbym najlepszym handlarzem przypraw w krainie.~
@19 = ~Rozumiem, ale to nie brzmi jak uczciwa praca! Znajdź sobie kogoś innego do brudnej roboty!~
@20 = ~Brzmi ciekawie. Co mam zrobić?~
@21 = ~Nic, co wyrządziłoby komukolwiek krzywdę. Powinieneś jedynie dodać nieco „pikanterii” spotkaniu Zakhuma z jego potencjalnym kontrahentem!~ ~Nic, co wyrządziłoby komukolwiek krzywdę. Powinnaś jedynie dodać nieco „pikanterii” do spotkania Zakhuma z jego potencjalnym kontrahentem!~
@22 = ~Mam tutaj pewną ciekawą papryczkę. Spokojnie, nie jest zatruta ani nic z tych rzeczy. Chcę tylko, żebyś podrzucił ją do reszty papryk w namiocie Zakhuma. Dzięki temu jego przyprawy staną się niezjadliwe, a wtedy klient, miejmy nadzieję, podpisze kontrakt ze MNĄ!~ ~Mam tutaj pewną ciekawą papryczkę. Spokojnie, nie jest zatruta ani nic z tych rzeczy. Chcę tylko, żebyś podrzuciła ją do reszty papryk w namiocie Zakhuma. Dzięki temu jego przyprawy staną się niezjadliwe, a wtedy klient, miejmy nadzieję, podpisze kontrakt ze MNĄ!~
@23 = ~Co będę z tego mieć?~
@24 = ~To zwykłe oszustwo! Nie chcę brać w tym udziału!~
@25 = ~Jeśli klient nie dobije targu z Zakhumem, wypłacę ci trzysta sztuk złota. To połowa tego, co sam bym na nim zarobił. No i jak – wchodzisz w to?~
@26 = ~Zgoda. Daj mi tą papryczkę, dorzucę ją do przypraw.~
@27 = ~Nie, nie przekonuje mnie to. Znajdź sobie innego naiwniaka do swoich machlojek!~ ~Nie, nie przekonuje mnie to. Znajdź sobie inną naiwniaczkę do swoich machlojek!~
@28 = ~Świetnie! Oto i ona...~
@29 = ~Będę tu na ciebie czekać! Gdy tylko klient wybiegnie ze sklepu oburzony, podejdę do niego z moją, znacznie lepszą ofertą!~
@30 = ~Wielka szkoda. No cóż, w takim razie będę musiał poszukać innych poszukiwaczy przygód. I pamiętaj – nigdy się nie spotkaliśmy!~
@31 = ~RATUNKU! POMOCY! ZŁODZIEJE!~ [AC#WSCRM]
@32 = ~*Zauważasz, że kupiec coś ci podłożył*.~
@33 = ~NIECH MI KTOŚ POMOŻE! OKRADLI MNIE!~ [AC#WSCRM]
@34 = ~Złodziej? Kto? Gdzie?~ ~Złodziejka? Kto? Gdzie?~
@35 = ~Nie wrzeszcz na mnie, człowieku!~
@36 = ~Potrzebujesz mojej pomocy, dobry człowieku?~
@37 = ~STRAŻ! DO MNIE! ŁAPAĆ ZŁODZIEJA!~ ~STRAŻ! DO MNIE! ŁAPAĆ ZŁODZIEJKĘ!~
@38 = ~Sam nie wiem, szczerze! Już dawno opuścił opactwo. Tylko proszę, nie karzcie mnie!~
@39 = ~Jaka czeka go kara, strażniku?~
@40 = ~Stać! Nikt się nie rusza!~
@41 = ~Masz dziś szczęście, koleżko! Wynoś się spod opactwa! Zapamiętam twoją gębę i jeśli jeszcze raz postawisz stopę na tej świętej ziemi, osobiście zakuję cię w kajdany!~
@42 = ~Słyszałeś, co powiedział ten jegomość. Marsz do kordegardy, utniemy ci rękę!~ ~Słyszałeś, co powiedziała ta kobieta. Marsz do kordegardy, utniemy ci rękę!~
@43 = ~A kielich zostaje skonfiskowany! Tobie, szlachetny panie, życzę wszystkiego dobrego. Dalej, obywatele, rozejść się! Nie ma tu nic do oglądania!~ ~A kielich zostaje skonfiskowany! Tobie, szlachetna pani, życzę wszystkiego dobrego. Dalej, obywatele, rozejść się! Nie ma tu nic do oglądania!~
@44 = ~Moje uszanowanie, lady Nalio. Słowo amnijskiej szlachcianki ma w tej sprawie szczególne znaczenie.~
@45 = ~Jaka jest zatem wasza wersja wydarzeń?~
@46 = ~Ten kupiec podrzucił mi kielich, by bezpodstawnie oskarżyć mnie o kradzież!~
@47 = ~Kupcze, twierdzisz, że cię okradziono? Kto to zrobił?~
@48 = ~Ten mężczyzna, imieniem <CHARNAME> – to on ukradł mi drogocenny kielich!~ ~Ta kobieta, imieniem <CHARNAME> – to ona ukradła mi drogocenny kielich!~
@49 = ~Twierdzisz, że okradł cię ten mężczyzna? Ty tam! Wytłumacz się!~ ~Twierdzisz, że okradła cię ta kobieta? Ty tam! Wytłumacz się!~
@50 = ~Miałbym coś ukraść temu człowiekowi? To śmieszne!~ ~Miałabym coś ukraść temu człowiekowi? To śmieszne!~
@51 = ~Tak! Tak! Strażniku, sam go sprawdź. Wciąż powinien mieć mój kielich w kieszeni!~ ~Tak! Tak! Strażniku, sam ją sprawdź. Wciąż powinna mieć mój kielich w kieszeni!~
@52 = ~Czy to prawda, co ten człowiek mówi?~
@53 = ~To kłamstwo! Ten facet przed chwilą specjalnie podrzucił mi kielich do kieszeni!~
@54 = ~To skąd niby u ciebie ten kielich?~
@55 = ~Podrzucił? To niedorzeczne!~
@56 = ~To doprawdy oburzająca wymówka!~
@57 = ~To nie wymówka, tylko prawda!~
@58 = ~Nie raz przysłużyłem się tej dzielnicy. Sądzisz, że ryzykowałbym to wszystko dla jednego kielicha?~ ~Nie raz przysłużyłam się tej dzielnicy. Sądzisz, że ryzykowałabym to wszystko dla jednego kielicha?~
@59 = ~Nie zmienia to faktu, że masz przy sobie kielich... o co w tym wszystkim chodzi?~
@60 = ~Nie! To niemożliwe! To... Och! Faktycznie. Kielich jest w mojej... a ja przecież...~
@61 = ~Chciałeś mi podrzucić ten kielich, żeby niesłusznie oskarżyć mnie o kradzież, prawda?~
@62 = ~Nie groź biednemu kupcowi, krasnoludzie!~
@63 = ~Ja mu niby grożę? Chcę go chronić! Przed moim toporem, który zaraz sam wyfrunie mi z ręki...!~
@64 = ~Nie! Czekajcie! Ja...~
@65 = ~*wzdycha* Kłamałem. Był tu taki człowiek w czarnych szatach, kazał mi czekać na kogoś imieniem <CHARNAME>. Miałem nie dopuścić, by dostał się do opactwa! Dlatego podrzuciłem mu ten kielich.~ ~*wzdycha* Kłamałem. Był tu taki człowiek w czarnych szatach, kazał mi czekać na kogoś imieniem <CHARNAME>. Miałem nie dopuścić, by dostała się do opactwa! Dlatego podrzuciłem jej ten kielich.~
@66 = ~Okłamałeś mnie, obywatelu, i niesłusznie oskarżyłeś tę niewinną osobę o kradzież?~
@67 = ~Gdzie jest teraz ten człowiek w czarnych szatach?~
@68 = ~Czy to prawda, kupcze? Próbowałeś rzucić fałszywe oskarżenie na tego uczciwego obywatela? Mów prawdę!~ ~Czy to prawda, kupcze? Próbowałeś rzucić fałszywe oskarżenie na tę uczciwą obywatelkę? Mów prawdę!~
@69 = ~Nie! Ja...~
@70 = ~*wzdycha* Tak, tak właśnie było. Był tu taki człowiek w czarnych szatach, kazał mi czekać na kogoś imieniem <CHARNAME> i powiedział, że nie mogę dopuścić, by dostał się do opactwa! Więc podrzuciłem mu ten kielich.~ ~*wzdycha* Tak, tak właśnie było. Był tu taki człowiek w czarnych szatach, kazał mi czekać na kogoś imieniem <CHARNAME> i powiedział, że nie mogę dopuścić, by dostała się do opactwa! Więc podrzuciłem jej ten kielich.~
@71 = ~Na szczęście wyjaśniliśmy tę sprawę.~
@72 = ~Chcę, by ten człowiek został ukarany!~
@73 = ~Hmm... w przypadku kradzieży winowajca traci prawą rękę. Całkiem możliwe, że ta zasada obowiązuje również przy takim zajściu.~
@74 = ~Ilmaterze, zlituj się nade mną! Nie! Błagam o przebaczenie!~
@75 = ~Nie do mnie należy decyzja.~
@76 = ~Nie martw się, strażniku. Nikomu nie stała się krzywda, a ten człowiek dostał już chyba nauczkę.~
@77 = ~Zbędne okrucieństwo nie jest potrzebne. Sugeruję, żebyśmy zamiast tego odcięli mu lewą rękę.~
@78 = ~Ten koleś musi stracić co najmniej prawą rękę! Najchętniej skróciłbym go o jego łeb!~
@79 = ~Chcesz puścić go wolno, mimo że fałszywie oskarżył cię o kradzież?~
@80 = ~Och, dziękuję, szlachetny panie! Nigdy ci tego nie zapomnę!~ ~Och, dziękuję, szlachetna pani! Nigdy ci tego nie zapomnę!~
@81 = ~Tak. Puśćcie go.~
@82 = ~Skoro taka wasza wola, niech będzie.~
@83 = ~Błagam, drogi panie! Oszczędź mnie!~ ~Błagam, droga pani! Oszczędź mnie!~
@84 = ~Chodź ze mną, nędzny kłamco. Wykonamy wyrok w kordegardzie!~
@85 = ~Zmieniłem zdanie. Puśćcie go wolno, już dostał nauczkę.~ ~Zmieniłam zdanie. Puśćcie go wolno, już dostał nauczkę.~
@86 = ~Mogę się temu przyglądać?~
@87 = ~Sprawiedliwa kara za nieuczciwy postępek.~
@88 = ~Gdybyśmy mieli ścinać każdego kłamcę czy złodzieja, kraj świeciłby pustkami. I byłoby mniej niewolników na galery! Nie, prawa ręka to wystarczająca kara.~
@89 = ~Nie. To nie zabawa, tylko kara dla przestępcy.~
@90 = ~Obywatele Amn, wierni wyznawcy Waukeen! Oto stał się cud!~ [AC#WTHAA]
@91 = ~A teraz, drodzy ludzie, wracajcie do domów. Roznieście tę dobrą nowinę po całym kraju! Niech nasi kapłani rozpoczną przygotowania do wspaniałych uroczystości. Do zobaczenia wkrótce w opactwie Złotych Iglic!~
@92 = ~...i wszystkiego najlepszego dla ciebie, <CHARNAME>!~
@93 = ~Chciałbym omówić z tobą coś jeszcze.~ ~Chciałabym omówić z tobą coś jeszcze.~
@94 = ~Dziękuję! Muszę już iść, nowe przygody czekają.~
@95 = ~Przyda mi się. Żegnaj.~
@96 = ~<CHARNAME>! Co jeszcze zaprząta twoją głowę?~
@97 = ~Jeśli chodzi o twoją duszę...~
@98 = ~W Otchłani natknąłem się na kapłana Cyrica, który próbował mnie powstrzymać. Wygląda na to, że w opactwie kryje się zdrajca.~ ~W Otchłani natknęłam się na kapłana Cyrica, który próbował mnie powstrzymać. Wygląda na to, że w opactwie kryje się zdrajca.~
@99 = ~Nic takiego. Żegnaj.~
@100 = ~Co? Masz na to jakieś dowody?~
@101 = ~Przyniosłem list, na który powinieneś spojrzeć.~ ~Przyniosłam list, na który powinieneś spojrzeć.~
@102 = ~Co tu jest napisane? „Misja ratunkowa bogini zdaje się nabierać rozpędu. Z podsłuchanych rozmów wynika, że osoba imieniem <CHARNAME> prowadzi wybawicieli w górę Nieskończonych Schodów, by dotrzeć do Samory w Azzagracie. Dopilnuj, aby ta wyprawa zakończyła się niepowodzeniem, a hojnie cię wynagrodzę – gdy tylko zostanę panią opactwa, po tym jak ten stary ramol, Tharundar Olehm, straci łaskę swoich wiernych”.~
@103 = ~Na Beshabę! Masz rację! Z treści listu jasno wynika, że zdrajczynią musi być kobieta. Mam sześć ambitnych akolitek, z których każda zabiega o łaskę bogini. Jestem niemal pewien, że to jedna z nich napisała ten list!~
@104 = ~Nie powinniśmy omawiać takich spraw tutaj, na zewnątrz. Spotkaj się ze mną w środku, na pierwszym piętrze.~
@105 = ~Muszę się już pożegnać, nowe przygody czekają.~
@106 = ~Wiesz o tym?~
@107 = ~Tak. Opowiedział mi o tym nalfeshnee Margrog.~
@108 = ~To było zło konieczne. Nie musisz tego rozumieć. Dla mnie też nie jest to łatwe, ale staram się żyć dalej i nie myśleć zbyt wiele o tym, co mnie czeka potem.~
@109 = ~Może ucieszy cię wiadomość, że ten nalfeshnee nie żyje.~
@110 = ~To decyzja podjęta bez myślenia o sobie. Szanuję ją.~
@111 = ~To najlepsze wyjście. Muszę już iść.~
@112 = ~Co? Jak to możliwe?~
@113 = ~Zabiłem go. Możesz zachować swoją duszę.~ ~Zabiłam go. Możesz zachować swoją duszę.~
@114 = ~Dziękuję za szczere słowa.~
@115 = ~Nie ma za co. A teraz żegnaj.~
@116 = ~Ocaliłeś nie tylko moją boginię, ale i mnie samego. <CHARNAME>! Jesteś prawdziwie wielkim bohaterem! I za to należy ci się nagroda. Odnajdź mnie później w opactwie – tam ją otrzymasz.~ ~Ocaliłaś nie tylko moją boginię, ale i mnie samego. <CHARNAME>! Jesteś prawdziwie wielką bohaterką!. I za to należy ci się nagroda. Odnajdź mnie później w opactwie – tam ją otrzymasz.~
@117 = ~Żegnaj. Drzwi naszego opactwa zawsze będą dla ciebie otwarte.~ [AC#WTHAI]
@118 = ~Nasza ukochana bogini powróciła!~ [AC#WTHAH]
@119 = ~Nasze modlitwy zostały wysłuchane!~ [AC#WCHEE]
@120 = ~Co za radość!~
@121 = ~Przyjaciółka Kupców powróciła!~
@122 = ~Spójrzcie, jak jej posąg lśni złotym blaskiem!~
@123 = ~...z nieba spadł nawet deszcz złotych monet!~
@124 = ~Teraz nie ma już wątpliwości – Waukeen powróciła do Panteonu, a my wciąż cieszymy się jej łaską!~ [AC#WTHAG]
@125 = ~Hurra!~ [AC#WCHEE]
@126 = ~Spłynął na nas dobrobyt!~
@127 = ~Nasz naród czeka nowa złota era!~
@128 = ~Arcykapłanie, kim jest ten osobnik u twego boku?~ ~Arcykapłanie, kim jest ta osobniczka u twego boku?~
@129 = ~Ten obywatel, drodzy ludzie, nazywa się <CHARNAME>. To on uwolnił i ocalił naszą boginię z łap piekielnego pomiotu! Niech jego bohaterski czyn będzie pamiętany przez wieki!~ ~Ten obywatelka, drodzy ludzie, nazywa się <CHARNAME>. To ona uwolniła i ocaliła naszą boginię z łap piekielnego pomiotu! Niech jej bohaterski czyn będzie pamiętany przez wieki~
@130 = ~Brawo <CHARNAME>!~ [AC#WCHEE]
@131 = ~Niech żyje <CHARNAME>!~
@132 = ~<CHARNAME>, nasz bohater!~ ~<CHARNAME>, nasza bohaterka!~
@133 = ~Niech żyje <CHARNAME>!~
@134 = ~Niech ci się szczęści, <CHARNAME>!~
@135 = ~Niech zawsze cieszy się błogosławieństwem Waukeen!~
@136 = ~Ta osoba to mój osobisty ochroniarz. Nie macie się czym martwić, obywatele. Co ważniejsze...~
@137 = ~Nasze opactwo wkrótce zorganizuje wystawne uroczystości, by uczcić przybycie naszej ukochanej bogini!~
@138 = ~Radziłbym wykorzystać ten sprzyjający czas i zawrzeć jak najwięcej umów handlowych. Nie będzie już lepszej okazji, by zyskać przychylność naszej kupieckiej patronki.~
@139 = ~Za Waukeen!~
@140 = ~Chwała naszej bogini!~
@141 = ~Patrz i podziwiaj, szlachetny panie! Mam świeże melony z Tethyru, dostarczone dziś rano! A może wolisz daktyle z Calimshanu lub figi z Hlondeth?~ ~Patrz i podziwiaj, szlachetna pani! Mam świeże melony z Tethyru, dostarczone dziś rano! A może wolisz daktyle z Calimshanu lub figi z Hlondeth?~
@142 = ~Świeże owoce! Najlepszy wybór! Bierzcie, póki jeszcze soczyste!~
@143 = ~Miodowe ciasto ze Shamedaru! Słodycze z dalekiego Turmish! Chodźcie i kosztujcie, dla każdego przygotowałem po kawałku!~
@144 = ~Cukierki! Wypieki! Wszystko, czego sąsiedzi będą wam zazdrościć!~
@145 = ~Ceramika z Keczulli! Pięknie malowane dzbany na wino, idealne na najwspanialsze uczty w Athkatli!~
@146 = ~Moje dzbany mają gwarancję – nie rozbiją się, nawet jeśli żona nimi w ciebie rzuci!~
@147 = ~Witajcie, nieznajomi. Jesteście tu bezpieczni, dopóki zachowujecie dobre maniery i nie sprawiacie kłopotów.~
@148 = ~Idźcie dalej, obywatele. Odciągacie mnie od służby.~
@149 = ~Przed świątynią stoi złodziej, który chce was okraść!~
@150 = ~Tak, tak, już wychodzę.~
@151 = ~Nie mam zamiaru nikomu przeszkadzać.~
@152 = ~Kolejny z tych szubrawców! Nasi ludzie się nim zajmą. Uczciwy z ciebie obywatel. Dziękuję za tę informację – opactwo znów jest trochę bezpieczniejsze.~ ~Kolejny z tych szubrawców! Nasi ludzie się nim zajmą. Uczciwa z ciebie obywatelka. Dziękuję za tę informację – opactwo znów jest trochę bezpieczniejsze.~
@153 = ~Dziękuję.~
@154 = ~Niech Przyjaciółka Kupców ci sprzyja.~
@155 = ~Witajcie, ludziska! Witajcie u Szczęściarza Aello, gdzie ceny są tak niskie, że aż coś musi być nie tak. Nikt nie sprzedaje taniej niż ja, bo nikt nie kupuje taniej niż ja. Jeśli znajdziecie gdzieś w Amn coś tańszego, to produkt pewnie was zabije. W czym mogę pomóc?~
@156 = ~Więc masz najtańsze towary w regionie? Rozejrzę się.~
@157 = ~Nie, dzięki, póki co nie interesują mnie twoje towary.~
@158 = ~Szczęściarz Aello? Nie prowadziłeś czasem sklepu we Wrotach Baldura?~
@159 = ~Bardzo dobrze. Pospieszcie się, bo moje towary rozchodzą się jak świeże bułeczki. Przy takich cenach to nic dziwnego!~
@160 = ~Ach, tak, to ja. Niestety, niedawno musiałem zamknąć interes z powodu... uch... niesprzyjających okoliczności. Przybyłem do Amn przedwczoraj i właśnie staram się o licencję na nowy sklep. Dlaczego pytasz?~
@161 = ~Nieważne. Pokaż mi po prostu, co tam masz.~
@162 = ~Sprzedałeś mi kupę złomu we Wrotach Baldura! Omal nie zabiłem dwóch towarzyszy, czytając twoje zwoje! Co ty na to?~ ~Sprzedałeś mi kupę złomu we Wrotach Baldura! Omal nie zabiłam dwóch towarzyszy, czytając twoje zwoje! Co ty na to?~
@163 = ~No, cóż... Zwoje i magiczne mikstury nie podlegają zwrotowi, jeśli o to ci chodzi. Poza tym nie gwarantuję, że cokolwiek kupionego u mnie będzie działać poprawnie, bo...~
@164 = ~Sugerujesz, że dla czystego zysku bezmyślnie narażasz życie swoich klientów?~
@165 = ~Tak, to znaczy... Nie! Ja... mógłbym zaoferować ci ten magiczny zwój w ramach rekompensaty, spójrz, prawdopodobnie jest bardzo potężny, jeśli...~
@166 = ~Naprawdę myślisz, że kiedykolwiek tknę jeszcze jakąś twoją rzecz?~
@167 = ~Szlachetny panie! Niezmiernie mi przykro, że miałeś takie komplikacje związane z moimi towarami, ale nie wiem, jak mógłbym ci to wynagrodzić. Poza tym zasiedziałem się tu stanowczo za długo i powinienem być już zupełnie gdzie indziej...~ ~Szlachetna pani! Niezmiernie mi przykro, że miałaś takie komplikacje związane z moimi towarami, ale nie wiem, jak mógłbym ci to wynagrodzić. Poza tym zasiedziałem się tu stanowczo za długo i powinienem być już zupełnie gdzie indziej...~
@168 = ~Stój! Ani kroku dalej! Pójdziesz ze mną i oddam cię w ręce straży!~
@169 = ~Chwileczkę, koleżko! Nie uciekniesz mi tak łatwo!~
@170 = ~Wynoś się stąd! Nie chcę cię tu więcej widzieć!~
@171 = ~Nie! Ja...~
@172 = ~O tak, obiecuję, że zniknę stąd natychmiast...~
@173 = ~Lestiulusie, mój stały kliencie! Co cię sprowadza tak daleko na południe?~
@174 = ~No, cóż... ja...~
@175 = ~Przykro mi, naprawdę, ale...~
@176 = ~Nie, litości, błagam...~
@177 = ~W końcu cię dopadłem, tłuściochu!~
@178 = ~Ty nędzny kanciarzu! Nie pamiętasz, w jakim stanie byłem, kiedy widzieliśmy się ostatnio?~
@179 = ~Zostałem zamieniony w kamień! A wszystko dlatego, że powąchałem jedną z twoich mikstur! Sześćdziesiąt nędznych dni stałem jako posąg pokryty ptasimi odchodami, dopóki mój bezużyteczny uczeń nie zdołał mnie odczarować z tego upokarzającego stanu!~
@180 = ~Przemierzyłem całe Wybrzeże Mieczy, żeby cię odnaleźć! Tysiące razy wyobrażałem sobie, co z tobą zrobię, gdy wreszcie cię dopadnę. I uwierz mi – żadna z tych rzeczy nie sprawi ci przyjemności!~
@181 = ~A kim są ci ludzie u twego boku? Podejrzewam, że to również poszkodowani klienci, którzy z pewnością przyznają mi rację!~
@182 = ~W istocie, nas też oszukał ten kanciarz.~
@183 = ~Cóż, zatem będziecie świadkami, jak z Faerûnu znika kolejny kretyn!~
@184 = ~To będzie ciekawe widowisko!~
@185 = ~Czekaj, nawet jeśli to łajdak, to z pewnością nie zasługuje na śmierć!~
@186 = ~No cóż, możesz mieć rację. Wymyślę coś innego, by ukarać tego typa za jego występki!~
@187 = ~Phi! Trzeba było pomyśleć wcześniej, komu wciskasz ten chłam. Teraz jest już za późno!~
@188 = ~No, zrobione! Co za piękny dzień! Żegnajcie, nieznajomi.~
@189 = ~No, ale z ciebie zabawny kurdupel! Trochę za tłusty jak na wiewiórkę, ale... Nieważne. Cóż za piękny dzień! Żegnajcie, nieznajomi.~
@190 = ~Słyszałem, że odkryto nowe, rozległe terytoria na zachodzie, za morzem. Jako szlachcic zamierzam mieć w tym swój udział! Wyobraźcie sobie te bogactwa czekające na odkrycie. Tubylcy są tam podobno bardzo słabi, więc złupienie tego podrzędnego kraiku będzie dziecinnie proste.~
@191 = ~Chcesz tak po prostu odebrać tym ludziom ich własność? Nie uważasz, że to zwykła kradzież?~
@192 = ~Dzięki za informację. Złożę im wizytę i dopilnuję, by uszczknąć dla siebie kawałek tego tortu.~
@193 = ~Całą wieczność czekam na audiencję u Arcykapłana. Moja cierpliwość powoli się kończy!~
@194 = ~Byłaby to kradzież, gdyby ta ziemia należała do nich. Na szczęście wkrótce będzie moja i będę mógł z nią robić, co mi się żywnie podoba. A teraz zmykaj.~
@195 = ~Tak zrób! Tylko nie rozpowiadaj o tym wszystkim, bo zaraz całe Amn wpadnie na pomysł, by zagarnąć te nowe ziemie dla siebie.~
@196 = ~Kolejny łotr połakomił się na nasze zakazane złoto, co? Patrzcie, ludzie, oto cena za bezprawne wzbogacanie się kosztem majątku Panny Monety!~
@197 = ~Niech posąg postoi tu jeszcze przez co najmniej dziesięć dni – ku przestrodze dla wszystkich złodziei i łajdaków, by nie ważyli się naruszać własności bogini. Potem sprzedamy go z porządnym zyskiem do Calimshanu, gdzie zostanie przetopiony na nowe dukaty.~
@198 = ~Chwała Pannie Monecie! Wybaczcie, interesy czekają.~
@199 = ~Udało się! Kawał porządnej roboty! Dzięki wam wślizgnąłem się do najświętszych zakamarków tego opactwa. Na łaskę Maski, żałuję, że nie mogłem wynieść wszystkiego! Chociaż zanim o mało mnie nie nakryli, zwędziłem wielki wór wypchany tymi starożytnymi złotymi monetami. Mówię wam, czyste złoto, lśniące i cieplutkie – widok warty każdych pieniędzy!~
@200 = ~Na pewno chcecie to zobaczyć, w końcu należy wam się uczciwa działka. Pewnie nie sądziliście, że wrócę, co? Ale ze mnie porządny złodziejaszek, zawsze dotrzymuję swojej części umowy.~
@201 = ~Dobra, gadajmy o złocie. Spójrzcie na tę monetę, to czysty kruszec, rzadkie znalezisko. Możemy je przetopić, uformować w sztabki i utrzymać nasz skok w tajemnicy. Darowałem sobie błyskotki i klejnoty. Ani wam, ani mnie nie uśmiecha się dać złapać, kapujecie?~
@202 = ~Wiecie, jak najłatwiej sprawdzić zawartość złota w monecie? Trzeba ją ugryźć. Złoto jest miękkie, zobaczcie, jaki na tej monecie został odcisk moich zębów. Weźcie monetę do ust, ugryźcie mocno...~
@203 = ~Jak idzie robota? Masz ten klucz?~
@204 = ~Tak, mam go. Wyjęcie go z kieszeni kapłanki było dziecinnie proste.~
@205 = ~Jeszcze nie. Pracuję nad tym.~
@206 = ~Dobra robota! Dawaj go, a ja zrobię swoje.~
@207 = ~W takim razie jeszcze tu chwilę pokręcę.~
@208 = ~Biorę się do roboty. Trzymajcie za mnie kciuki! Spotkamy się tutaj najpóźniej jutro.~
@209 = ~Wy tam, wyglądacie mi na bandę twardzieli. Jestem Maendir. Chcecie poznać pewien sekret?~
@210 = ~Mów śmiało, ale jak mi powiesz, to pewnie nie będzie to już żaden sekret.~
@211 = ~To już od pierwszego zdania cuchnie podłym spiskowaniem. Precz stąd, łotrze, zanim zawołam straże!~
@212 = ~Zachowaj swoje sekrety dla siebie.~
@213 = ~Nie jestem na tyle głupi, żeby wygadać wszystko. To zgromadzenie nie bez powodu poświęcono Pannie... Monecie, rozumiecie?~
@214 = ~Nie, nie rozumiem.~
@215 = ~Sądzisz, że ukryto tutaj wielki skarb?~
@216 = ~Brzmi jak początek jakiejś parszywej historii. Precz stąd, łotrze, zanim zawołam straże!~
@217 = ~Nie trzeba się od razu złościć. Zaczerpnę świeżego powietrza za bramami, dopóki atmosfera tutaj się nie oczyści.~
@218 = ~Ależ bez urazy. Tak tylko zapytałem.~
@219 = ~Na cienie, ale z was ciężko myślące typy. Próbuję wam powiedzieć, że leży tu trochę grosza, który tylko czeka na... uczciwego znalazcę, łapiecie?~
@220 = ~No, teraz to co innego.~
@221 = ~Wiem nawet, gdzie może być, ale nie mogę zdobyć klucza.~
@222 = ~Domyślam się, o co chodzi. Chcesz, bym go dla ciebie zdobył, prawda?~ ~Domyślam się, o co chodzi. Chcesz, bym go dla ciebie zdobyła, prawda?~
@223 = ~Kto ma ten klucz?~
@224 = ~To brzmi jak parszywa sprawa. Wynocha, zanim zawołam straże!~
@225 = ~Ciekawe, co na to powiedzą strażnicy?~
@226 = ~Nie interesuje mnie to.~
@227 = ~Nic, bo nigdy się nie dowiedzą. I nigdy mnie nie widzieliście...~
@228 = ~Właśnie dlatego potrzebuję waszej pomocy. Macie zaproszenie od jednej z tutejszych szych, co? Dzięki temu szybciej ode mnie dorwiecie się do klucza.~
@229 = ~Myślisz, że jedna z kapłanek nosi go przy sobie?~
@230 = ~Ciii! Ciszej, kolego! Nigdy nie wiadomo, kto tu nadstawia uszu. Moim zdaniem szukamy kapłanki Faerthae Garblueth. Szkoda, że taki poczciwy chłop jak ja nie może zbliżyć się do takiej damy. Wy możecie po prostu podejść i zagadać, co nie? Pomyślałem, że może moglibyście zwinąć dla mnie ten malutki kluczyk.~ ~Ciii! Ciszej, koleżanko! Nigdy nie wiadomo, kto tu nadstawia uszu. Moim zdaniem szukamy kapłanki Faerthae Garblueth. Szkoda, że taki poczciwy chłop jak ja nie może zbliżyć się do takiej damy. Wy możecie po prostu podejść i zagadać, co nie? Pomyślałem, że może moglibyście zwinąć dla mnie ten malutki kluczyk.~
@231 = ~Nawet jeśli udałoby mi się go ukraść, sądzisz, że ludzie nie zauważą braku pieniędzy?~
@232 = ~Nie chcę mieć nic wspólnego z kradzieżą z włamaniem!~
@233 = ~Nie chcę kraść wszystkiego! Nawet nie zdołałbym tego unieść. Moim zdaniem dopiero za kilka tygodni zorientują się, że mają jakieś braki, a do tego czasu będę... to znaczy my... będziemy już daleko stąd!~
@234 = ~Sprytne rozumowanie! A co właściwie dostanę za ryzykowanie własną skórą?~
@235 = ~Moje usługi nie są darmowe. Co oferujesz w zamian?~
@236 = ~Hej, nie proszę, żebyście robili to za darmo. Oferuję wam kawałek tortu. Co powiecie na jedną czwartą łupu? Stoi?~
@237 = ~Oszalałeś? To ja podejmuję większe ryzyko! Żądam trzech czwartych łupu, inaczej zapomnij o sprawie!~
@238 = ~To za mało. Sugeruję podział pół na pół.~
@239 = ~Chcę jednej trzeciej łupu. W przeciwnym razie poszukaj sobie kogoś innego.~
@240 = ~Zgoda.~
@241 = ~No cóż... hmm... w porządku. Jesteś twardym negocjatorem, ale nie mam wyboru. Dostaniesz trzy czwarte.~ ~No cóż... hmm... w porządku. Jesteś twardą negocjatorką, ale nie mam wyboru. Dostaniesz trzy czwarte.~
@242 = ~Niech będzie. Jesteś twardym negocjatorem, ale nie mam wyboru. Dostaniesz połowę.~ ~Niech będzie. Jesteś twardą negocjatorką, ale nie mam wyboru. Dostaniesz połowę.~
@243 = ~No cóż... hmm... w porządku. Jesteś twardym negocjatorem, ale nie mam wyboru. Dostaniesz jedną trzecią.~ ~No cóż... hmm... w porządku. Jesteś twardą negocjatorką, ale nie mam wyboru. Dostaniesz jedną trzecią.~
@244 = ~Idealnie. Wiedziałem, że warto z wami robić interesy.~
@245 = ~Zostanę w cieniu opactwa, a wy zajmijcie się swoją część. Wróćcie, gdy tylko zdobędziecie klucz.~
@246 = ~Zakładam, że sama urzędująca kapłanka, Faerthae Garblueth.~
@247 = ~Twierdzisz, że kapłanka ma klucz i mam go dla ciebie ukraść?~
@248 = ~Najdroższy kupcze, to niemożliwe! Mylisz się. Kielich wciąż tkwi w twojej szacie – dokładnie tam, gdzie sam go schowałeś po tym, jak nie doszliśmy do porozumienia handlowego, gdy próbowałeś wyciągnąć od nas skandalicznie wygórowaną sumę za tę tanią podróbkę lantanskiego płomiennego kielicha!~
@249 = ~Strażniku, twoja gorliwość w pełnieniu obowiązków jest godna pochwały, lecz bezpodstawnie nas podejrzewasz. Stało się dokładnie tak, jak mówi mój towarzysz – kielich został nam podrzucony, zapewne po to, by fałszywie oskarżyć nas o kradzież. Jestem Nalia d'Arnise i ręczę, że <CHARNAME> niczego nie ukradł. Spójrz – oto mój sygnet.~ ~Strażniku, twoja gorliwość w pełnieniu obowiązków jest godna pochwały, lecz bezpodstawnie nas podejrzewasz. Stało się dokładnie tak, jak mówi moja towarzyszka – kielich został nam podrzucony, zapewne po to, by fałszywie oskarżyć nas o kradzież. Jestem Nalia d'Arnise i ręczę, że <CHARNAME> niczego nie ukradła. Spójrz – oto mój sygnet.~
@250 = ~Cóż za bezwstydna zuchwałość! Jestem Anomen Delryn i nikt nie będzie oskarżał mnie ani moich towarzyszy o złodziejstwo! Ten kupiec próbuje zrobić z ciebie głupca, żołnierzu. Wcisnął nam swoje błyskotki! Przesłuchaj go osobiście – wobec prawa jego kłamstwa nie przejdą mu już tak łatwo przez gardło.~
@251 = ~A teraz słuchaj uważnie, dowcipnisiu! Może i potrafisz okłamać mnie, ale nie moją broń! To krasnoludzki, magiczny topór stworzony do wykrywania kłamstw. Wiesz, co robi, gdy ktoś próbuje mnie oszukać? Śmiga prosto w twarz kłamcy. Zostawia paskudną bliznę – jak możesz sobie wyobrazić.~
@252 = ~Policzę do trzech. Jeśli nie wyśpiewasz prawdy, nie zdołam utrzymać topora w garści!~
@253 = ~Jesteś marnym kłamcą, kupcze! Naprawdę sądziłeś, że zdołasz okłamać paladyna Zakonu Promiennego Serca? Nie wierzcie mu, żołnierzu. Ja, Keldorn Firecam, lojalny sługa Torma, zapewniam was, że nie zrobiliśmy nic złego!~
@254 = ~Nie wymierzajcie kary kupcowi, ale żądam rekompensaty za moje kłopoty!~
@255 = ~W takim razie zatrzymaj kielich, który próbowano ci podrzucić. Ciebie, „kupcze”, odprowadzę do kordegardy. Żegnaj, szlachetny panie. Dobrze się stało, że postawiłeś tego oszusta przed wymiarem sprawiedliwości.~ ~W takim razie zatrzymaj kielich, który próbowano ci podrzucić. Ciebie, „kupcze”, odprowadzę do kordegardy. Żegnaj, szlachetna pani. Dobrze się stało, że postawiłaś tego oszusta przed wymiarem sprawiedliwości.~
@256 = ~Moje dzbany mają gwarancję – nie rozbiją się, nawet jeśli rzucisz nimi w męża!~
@257 = ~Hej! Dlaczego coś mi podrzucasz?~
@258 = ~C-co? Zauważyłeś?~ ~C-co? Zauważyłaś?~
@259 = ~Oczywiście, że zauważyłem. Miałeś zamiar oskarżyć mnie o kradzież tego przedmiotu?~ ~Oczywiście, że zauważyłam. Miałeś zamiar oskarżyć mnie o kradzież tego przedmiotu?~
@260 = ~Zapomnij o tym.~
@261 = ~Och, ja... proszę o wybaczenie, szlachetny panie. Był tu taki człowiek w czarnych szatach, kazał mi wypatrywać kogoś takiego jak ty i upewnić się, że straże cię aresztują. Oferował całkiem sporo złota, a ponieważ interesy idą teraz kiepsko, pomyślałem...~ ~Och, ja... proszę o wybaczenie, szlachetna pani. Był tu taki człowiek w czarnych szatach, kazał mi wypatrywać kogoś takiego jak ty i upewnić się, że straże cię aresztują. Oferował całkiem sporo złota, a ponieważ interesy idą teraz kiepsko, pomyślałem...~
@262 = ~Pomyślałeś, że możesz mnie wrobić w kradzież?~
@263 = ~Tak, coś w tym stylu. Nie szukam z tobą zwady! Ten mroczny człowiek mnie do tego zmusił!~
@264 = ~Gdzie on teraz jest?~
@265 = ~Nie wiem. Ale... o, patrzcie! Tam, na górze – ptak! Zmywam się stąd...~
@266 = ~*Nic nie rób i patrz, co się wydarzy*.~
@280 = ~Witajcie, poszukiwacze przygód! Jestem Nuksheid Rheshan, kupiec z dalekiego Calimshanu. Widzę, że macie oko do magicznych skarbów – a mogę was zapewnić, że moja oferta was nie zawiedzie.~
@281 = ~Nie widziałem cię tu wcześniej. Co sprowadza cię do opactwa Złotych Iglic?~ ~Nie widziałam cię tu wcześniej. Co sprowadza cię do opactwa Złotych Iglic?~
@282 = ~Co masz w ofercie?~
@283 = ~Pokaż mi swoje towary.~
@284 = ~W tej chwili niczego nie potrzebuję.~
@285 = ~Pozdrowienia, poszukiwacze przygód! Zainteresowani moimi wybornymi wyrobami z Calimshanu?~
@286 = ~Szczęśliwy zbieg okoliczności, przyjaciele! Słyszałem o cudzie w opactwie i nie mogłem sobie odmówić, by zobaczyć, jak handel znów lśni pełnym blaskiem. Przybyłem tu prosto z Athkatli – choć pierwotnie zmierzałem do Waterdeep. Przy tym całym ożywieniu wśród kupców jestem pewien, że zostanę tu na dłużej i dobiję niejednego olśniewającego targu!~
@287 = ~Od urzekających amuletów po lśniące kostury – mam wszystko, czego dusze poszukiwaczy przygód mogą zapragnąć. Moje towary są najwyższej jakości, gwarantuję! Tylko to, co najlepsze dla moich cennych klientów.~
@288 = ~Oczywiście, moi przyjaciele! Będę tutaj, by dostarczać wam najwspanialsze magiczne przedmioty. Wpadajcie kiedykolwiek chcecie i niech Tymora zawsze wam sprzyja!~
@289 = ~Spójrzcie na te wszystkie rzeczy. Możliwości są nieskończone i jestem pewien, że znajdziecie coś, co sprawi, że serce poszukiwacza przygód zabije szybciej!~
@290 = ~Hej, musicie to zobaczyć! Właśnie przyjechał nowy kupiec i rozdaje dzieciom cukierki!~
@291 = ~Gdzie jest ten nowy kupiec?~
@292 = ~W takim razie bierz, ile wlezie.~
@293 = ~Mam nadzieję, że ci smakują.~
@294 = ~Zostaw mnie w spokoju, dzieciaku!~
@295 = ~Idź do domu, robi się późno.~
@296 = ~No tam! W zielonym namiocie! Polecę do Dzielnicy Mostów i powiem Mukhenowi, Lozie i Daldrimowi. Ale Falme nie powiem.~
@297 = ~Chyba mam już dość. I tak nie mogę już nic przełknąć. Brzuszek mnie już boli.~
@298 = ~Jest już późno. Świętowanie dobiegło końca. Wracaj do domu, dziecko.~
@299 = ~Ale on mówił, że na północy nie ma takich dobroci, są tylko tam gdzie on był, w Calimshanie! Dlatego chcę najeść się, ile się da!~
@300 = ~W porządku. Gdybyście kiedyś zmienili zdanie lub poczuli potrzebę, wiecie, gdzie mnie znaleźć.~
@301 = ~Jesteśmy tylko postronnymi obserwatorami.~
@302 = ~Spotkamy się w środku na poufną rozmowę.~