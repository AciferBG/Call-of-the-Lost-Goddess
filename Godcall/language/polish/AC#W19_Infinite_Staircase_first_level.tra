@0 = ~Spójrzcie tylko, powrócił! Świętujmy wszyscy w tym magicznym miejscu i pozwólmy, by godziny mijały niczym dni!~ ~Spójrzcie tylko, powróciła! Świętujmy wszyscy w tym magicznym miejscu i pozwólmy, by godziny mijały niczym dni!~
@1 = ~Słyszycie pieśń Nieskończonych Schodów, moi drodzy? Ten melodyjny zaśpiew niosący się po stopniach?~
@2 = ~Niech taniec nas wyzwoli, a śpiew zjednoczy! Na Nieskończonych Schodach stanowimy jedność ze światem i tętniącym rytmem wszechświata!~
@3 = ~Tutaj, gdzie przenikają się rzeczywistości, dajemy się porwać muzyce chwili!~
@4 = ~O tak, to symfonia wypraw i wielkich przygód! Śpiewajmy z radości, niech nasze serca wtórują tej pieśni!~
@5 = ~Niech nasze serca tańczą w rytm wesela, gdy wspinamy się po stopniach i nasycamy świat naszym szczęściem.~
@6 = ~Nieskończone Schody to początek drogi bez końca, na której porywa nas każdy krok. Świętujmy życie we wszystkich jego barwach!~
@7 = ~Spójrzcie, kto do nas dołączył! Dzielna grupa poszukiwaczy przygód! Witajcie na Nieskończonych Schodach, odważni podróżnicy! Niech ich magia was urzeknie, niech wasze serca radosne będą!~
@8 = ~Kim jesteście?~
@9 = ~Co możecie mi powiedzieć o Nieskończonych Schodach?~
@10 = ~Jesteście nieznośnie radośni. Żegnajcie.~
@11 = ~Jestem eladrinem, istotą ze Sfery Faerie. Nasza biegłość w magii i muzyce obrosła legendami, a my zaś sami słyniemy z głębokiej więzi z naturą.~
@12 = ~Jestem satyrem. Moja radość życia jest zaraźliwa – kocham otaczać się muzyką, tańcem i wesołością.~
@13 = ~Jestem bariaurem. Wolnym duchem, który kocha przemierzać bezkresne sfery Ysgardu.~
@14 = ~Skoro wyjawiliśmy tak wiele o sobie, pozwól, że spytamy: kim ty jesteś?~
@15 = ~Nazywam się <CHARNAME>.~
@16 = ~Nie mam zamiaru o tym rozmawiać.~
@17 = ~Alae, <CHARNAME>, niech ci się dobrze wędruje. Powiedz nam, dokąd prowadzi cię ścieżka po tych stopniach?~
@18 = ~Do Otchłani.~
@19 = ~Otchłań... miejsce grozy i zniszczenia. Wybacz, nie potrafię pojąć, dlaczego dobrowolnie zapuszczasz się w tak niebezpieczne rejony. Nie ma lepszych, bezpieczniejszych sfer do zwiedzania?~
@20 = ~Jako wolne duchy natury dążymy do harmonii i światłości, a Otchłań stoi w rażącej sprzeczności z naszymi zasadami. Niech twoja odwaga i determinacja prowadzą cię i chronią, gdy przyjdzie ci spojrzeć w oczy horrorom Otchłani.~
@21 = ~Otchłań? Brzmi jak dzika i niebezpieczna przygoda! Nie trać ducha, ufaj swej sile i męstwu.~
@22 = ~Dzięki za radę.~
@23 = ~Muszę się już pożegnać.~
@24 = ~Nieskończone Schody? To miejsce prawdziwie magicznego piękna! Stopnie ciągną się we wszystkich kierunkach, jakby prowadziły do najdalszych zakątków wieloświata. I tak właśnie jest!~
@25 = ~Właśnie tak! Nieskończone Schody napełniają serca trwogą i podziwem. Tutaj różne światy, rzeczywistości i wymiary przenikają się w cudowny sposób. Stawiając na nich krok, jesteś wszędzie i nigdzie jednocześnie!~
@26 = ~Schody stoją otworem przed każdym, kto ma odwagę ruszyć na wyprawę. Nie mają końca ani granic – czeka nas tylko bezkresna przestrzeń do odkrycia!~
@27 = ~Nieskończone Schody to miejsce, w którym najgłębsze tęsknoty i pragnienia serca nabierają kształtów. Każda istota znajdzie tu szczególne miejsce ucieleśniające to, za czym najbardziej tęskni.~
@28 = ~Dzięki za opowieść. Żegnajcie.~
@29 = ~Jesteście nieznośnie pogodni. Żegnajcie.~
@30 = ~Zatem żegnaj. Wejdź na Nieskończone Schody z uśmiechem na ustach. Witamy cię i życzymy, byś odnalazł własną drogę.~ ~Zatem żegnaj. Wejdź na Nieskończone Schody z uśmiechem na ustach. Witamy cię i życzymy, byś odnalazła własną drogę.~
@31 = ~Nie pozwolimy, by tak zrzędliwa istota zepsuła nam humor. Dalej, przyjaciele, schody wzywają!~
@32 = ~Witaj, <CHARNAME>! Napijemy się znowu razem?~
@33 = ~Pokaż, co tam masz.~
@34 = ~Co z ciebie za stworzenie?~
@35 = ~Co tutaj robisz?~
@36 = ~Nie tym razem. Muszę ruszać w drogę. Żegnaj.~
@37 = ~Pozdrawiam raz jeszcze, wędrowcy!~
@38 = ~Miło cię poznać. Nazywam się <CHARNAME>.~
@39 = ~Muszę ruszać w drogę. Żegnaj.~
@40 = ~Pozdrawiam, wędrowcy! Rzadko widuje się obcych w tej części schodów. Nazywam się Gwiezdny Ogon i ten mały skrawek stopni nazywam swoim domem.~
@41 = ~Pewnie wydaję ci się równie dziwny, jak ty mnie. Jestem bariaurem. Moi kuzyni przemierzają równiny Ysgardu, ja jednak  od tamtejszych bezkresnych stepów wolę spokój i samotność schodów.~
@42 = ~Co tu robię? Po prostu żyję. Po latach wędrówki w końcu znalazłem miejsce, które mi odpowiada. Zostanę tu, dopóki pewnego dnia znów nie poczuję zewu przygody.~
@43 = ~Miło cię poznać, <CHARNAME>! Co cię sprowadza w te strony?~
@44 = ~Jestem w drodze do Otchłani.~
@45 = ~Nie mogę ci tego wyjawić.~
@46 = ~Oho, tajna misja, co? Twoja sprawa. W każdym razie większość tych, którzy tak bardzo strzegli swoich tajemnic, nigdy stąd nie wróciła.~
@47 = ~Na liście Silvanusa! Wybraliście sobie niezbyt gościnne miejsca na wyprawę. To jednak wasza sprawa. Nie będę was od tego odwodzić, choć takie rejony nie są stworzone dla istot ze Sfer Wyższych jak ja.~
@48 = ~Skoro znamy się już nieco lepiej, nie dołączylibyście do mnie na kolejkę lub dwie? Mam w moim skromnym domostwie kilka wybornych trunków, które chętnie zaoferuję... oczywiście za niewielką opłatą!~
@49 = ~Napijmy się razem i zapomnijmy na chwilę o samotności!~
@50 = ~Zatem żegnaj. Niech twoja ścieżka nigdy nie skręci w niewłaściwą stronę!~
@51 = ~Wielką zagadką pozostaje, kto właściwie zapoczątkował budowę Nieskończonych Schodów. Krążą plotki, że stworzył je dawno zapomniany bóg podróży albo patron budownictwa i wynalazków.~
@52 = ~Nikomu nie udało się dotąd ustalić, czy Nieskończone Schody są naprawdę bezkresne. W każdym razie nikt nie odnalazł ich krańca i nie wrócił, by o tym opowiedzieć.~
@53 = ~Mówi się, że ktokolwiek dotrze do końca tych schodów, ginie na miejscu i sam staje się kolejnym stopniem. Dość niepokojąca myśl, nie uważasz?~
@54 = ~W Sferach Zewnętrznych wiele czarów, które znasz ze Sfery Materialnej, działa inaczej. Na przykład podczas podróży przez Otchłań musisz uważać, by twoja magia nie została spaczona bez odpowiedniego klucza czarów. Takie klucze są drogie i zazwyczaj oferują je szemrani handlarze.~
@55 = ~Lillendi to jedyne stworzenia, które nazywają to miejsce domem. To pokojowe istoty, ale strzegą schodów z całych sił. Żyjcie z nimi w zgodzie.~
@56 = ~Witaj, śmiertelniku! Przybywasz podziwiać cuda Nieskończonych Schodów? Jak cię zowią?~ ~Witaj, śmiertelniczko! Przybywasz podziwiać cuda Nieskończonych Schodów? Jak cię zowią?~
@57 = ~Witaj, nazywam się <CHARNAME>. A ty kim jesteś?~
@58 = ~Moje imię to Adonia.~
@59 = ~Co to za miejsce?~
@60 = ~Co z ciebie za istota? Jesteś devą?~
@61 = ~Powiesz mi, jak korzystać z Nieskończonych Schodów? Na co muszę uważać?~
@62 = ~Nie, nie jestem devą, <CHARNAME>. Należę do rasy lillendi – jesteśmy sługami Księżycowej Panny i naszym zadaniem jest strzec tej części Nieskończonych Schodów.~
@63 = ~To Argentil, domena Selûne. Znajdujesz się wysoko ponad sferą Ysgardu. To tutaj zaczynają się Nieskończone Schody, które przecinają wszystkie sfery tego świata.~
@64 = ~Doprawdy? Więc to tutaj mieszka bogini Selûne?~
@65 = ~Właśnie tak. Jednak nie przebywa ona obecnie w swym pałacu – przemierza Sfery Zewnętrzne w poszukiwaniu sojuszników do walki ze swą mroczną siostrą.~
@66 = ~Kim jest ta mroczna siostra?~
@67 = ~To Shar, Pani Nocy. Od momentu narodzin Torilu obie toczą zaciętą walkę o dominację. Obecnie wpływy Shar zdają się ponownie rosnąć, co niepokoi Księżycową Pannę.~
@68 = ~Nieskończone Schody stanowią zagadkę nawet dla nas, lillendich, choć czujemy się z nimi silnie związane.~
@69 = ~Ponieważ schody nie mają końca, ryzykujesz, że się na nich zgubisz. Nie daj się zwieść pozorom.~
@70 = ~I strzeż się innych podróżników! Każda istota ma prawo korzystać z tego szlaku, więc na swojej drodze spotkasz siły zarówno dobra, jak i zła. Od tych drugich trzymaj się z daleka.~
@71 = ~Nie mam jednak ważniejszej rady niż ta: trzymaj się wybranej ścieżki! Podczas wędrówki miniesz niezliczone portale prowadzące do najdalszych zakątków wieloświata. Wygląd i charakter bramy mówi wiele o tym, co za nią się kryje. Unikaj mrocznych wrót – za większością z nich czai się śmierć, a w ich pobliżu krążą potworne istoty, które trafiły tu przez przypadek i utknęły na schodach.~
@72 = ~Nie chcę cię już dłużej zatrzymywać, moje obowiązki nie znoszą zwłoki. Żegnaj, <CHARNAME>, i pamiętaj o moich radach...~
@73 = ~Jesteś więc wyznawczynią nienawistnej Mrocznej Bogini? Ostrzegam: z Nieskończonych Schodów może korzystać każda istota, ale nie licz na przychylność mego rodzaju, kapłanko Shar.~
@74 = ~Podróżujesz w podejrzanym towarzystwie, <CHARNAME>. Będziemy cię obserwować.~
@75 = ~Chodzi o Shar, marnoto. I nie ma wątpliwości, kto wygra tę walkę między światłem a ciemnością.~
@80 = ~Chwileczkę, wędrowcze. Skoro poznaliśmy się już nieco lepiej, chciałabym cię prosić o przysługę.~ ~Chwileczkę, wędrowczyni. Skoro poznaliśmy się już nieco lepiej, chciałabym cię prosić o przysługę.~
@81 = ~Jasne, o co chodzi?~
@82 = ~Nie mam na to czasu.~
@83 = ~Jak chcesz. Niech Selûne błogosławi cię i strzeże.~
@84 = ~Młody bard, Riven Kroczący z Wiatrem, od dłuższego czasu się tu nie pojawił. To wyznawca Selûne, podobnie jak ja. Często towarzyszył mi w zgłębianiu tajemnic Nieskończonych Schodów. Jego pasja do nocy, jej sekretów i potęgi księżyca zawsze znajdowała odbicie w jego pieśniach. Nie słyszałam o nim jednak od kilku miesięcy i obawiam się, że mogło mu się przytrafić coś złego.~
@85 = ~Bardzo się o niego martwię. Zamierzał skomponować balladę o Nieskończonych Schodach, ale jego ścieżka powiodła go w mrok, z którego dotąd nie powrócił. Proszę, poszukaj go. Mógł zabłądzić gdzieś na stopniach.~
@86 = ~W porządku. Będę się za nim rozglądać podczas dalszej wędrówki.~
@87 = ~Bard nie żyje. Mam przy sobie jego poemat, który znalazłem przy zwłokach na stopniach Nieskończonych Schodów.~ ~Bard nie żyje. Mam przy sobie jego poemat, który znalazłam przy zwłokach na stopniach Nieskończonych Schodów.~
@88 = ~Dziękuję. Mówił o tajemnicach schodów z taką pasją, że z pewnością go rozpoznasz, gdy go spotkasz. Być może wciąż pracuje nad swym poematem. Proszę, sprowadź go bezpiecznie, jeśli tylko zdołasz.~
@89 = ~Cóż za straszne wieści! Daj mi rzucić okiem na ten tekst...~
@90 = ~To pismo Rivena, poznaję jego elegancję i styl. Smutny to dzień. O, mój biedny Rivenie! Tak żarliwie badał te schody. Jego strata jest bolesna. Niech Selûne przyjmie jego ducha w swe wieczne progi, a jego ciało niech stanie się kolejnym stopniem Nieskończonych Schodów.~
@91 = ~Dziękuję za odnalezienie go i zwrot poematu. Świadomość, że może teraz spoczywać w pokoju i wciąż żyć w swej poezji, przynosi pocieszenie. W nagrodę weź te bransolety. Niech prowadzą cię bezpiecznie przez noc i mroczne miejsca.~
@92 = ~Witaj ponownie, wędrowcze. Jak mogę cię wesprzeć darami księżyca?~ ~Witaj ponownie, wędrowczyni. Jak mogę cię wesprzeć darami księżyca?~
@93 = ~Pokaż mi swoją ofertę.~
@94 = ~Jakie przedmioty masz na sprzedaż?~
@95 = ~Co cię sprowadza na Nieskończone Schody?~
@96 = ~Bard Riven Kroczący z Wiatrem nie żyje. Mam przy sobie jego poemat, który znalazłem przy zwłokach na stopniach Nieskończonych Schodów.~ ~Bard Riven Kroczący z Wiatrem nie żyje. Mam przy sobie jego poemat, który znalazłam przy zwłokach na stopniach Nieskończonych Schodów.~
@97 = ~Dziękuję, Elandro. Muszę już ruszać w drogę.~
@98 = ~Jako strażniczka księżycowej magii i kapłanka czcigodnej Selûne oferuję wybór magicznych przedmiotów oraz czarów powiązanych z potęgą księżyca i błogosławieństwem bogini. Posiadam również zaklęcia zapewniające ochronę w ciemnościach. W czym mogę ci pomóc?~
@99 = ~Dziękuję, Elandro. Muszę już ruszać w drogę.~
@100 = ~Nieskończone Schody to twór sfer, który prowadzi wędrowców takich jak ty do najdalszych krańców rzeczywistości. Sama zostałam wyznaczona przez Selûne, by służyć na tych schodach i oferować podróżnym przychylność księżyca. Wyjawisz mi, dokąd prowadzi cię droga?~
@101 = ~Pokaż mi najpierw, co masz na sprzedaż.~
@102 = ~Nie, nie chcę mówić, dokąd się udaję.~
@103 = ~Wędrujemy do Otchłani.~
@104 = ~Twoje cele są dla ciebie święte i zapewne mają wielką wagę, szanuję więc decyzję o milczeniu. Wybrane przez nas ścieżki czasem lepiej ukryć w mroku. Jeśli będziesz potrzebować rady lub wsparcia, ja, służka Selûne, pozostaję do twojej dyspozycji w mgłach niepewności.~
@105 = ~Żegnam.~
@106 = ~Ach! Otchłań... kraina nieskończonej grozy i niezmierzonej ciemności, miejsce chaosu i ruiny. Kryje niebezpieczeństwa, których nie przebije nawet światło księżyca. Mimo to wasza próba wejścia w to miejsce może być odważną i honorową sprawą.~
@107 = ~Musisz wiedzieć, że większość demonów jest niewrażliwa na zwykłą broń. Będziesz potrzebować zaczarowanego lub posrebrzanego oręża, by zadać rany tym biesom. Mam na sprzedaż kilka posrebrzanych ostrzy. Stworzono je do walki z likantropami, wrogami Księżycowej Panny, ale posłużą ci dobrze również podczas wyprawy w głębiny Otchłani.~
@108 = ~Czy zechcesz zatem, bym przed tą niebezpieczną podróżą wsparła cię błogosławieństwem Selûne i darami księżyca?~
@109 = ~Chętnie! Pokaż mi, co masz w ofercie.~
@110 = ~Niech blask księżyca oświetla twoją drogę i zapewnia ci ochronę podczas wędrówki. Jeśli znów będziesz potrzebować mojej pomocy, znajdziesz mnie tutaj, na Nieskończonych Schodach.~
@111 = ~Oczywiście, drodzy podróżnicy. Oto przedmioty i czary, które przygotowałam...~
@112 = ~Niech światło księżyca ci błogosławi, wędrowcze. Jestem Elandra Księżycowa Pieśń, służka Selûne. Jakimi darami księżyca mogę cię wesprzeć?~ ~Niech światło księżyca ci błogosławi, wędrowczyni. Jestem Elandra Księżycowa Pieśń, służka Selûne. Jakimi darami księżyca mogę cię wesprzeć?~